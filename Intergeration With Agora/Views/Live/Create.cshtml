@model Intergeration_With_Agora.DTOs.SessionRequest

<form asp-controller="Live" asp-action="CreateSession" method="post">
    <!-- حطي الـ Inputs بتاعتك هنا -->
    <input type="hidden" asp-for="CourseId" value="@ViewBag.CourseId" />

    <div class="form-group">
        <label>Title</label>
        <input asp-for="Title" class="form-control" required />
    </div>

    <div class="form-group">
        <label>Start Date</label>
        <input asp-for="ScheduledStart" type="datetime-local" class="form-control" required />
    </div>

    <div class="form-group">
        <label>Duration (Minutes)</label>
        <input asp-for="DurationInMinutes" type="number" class="form-control" required />
    </div>

    <button type="submit" class="btn btn-success">Start Live Now</button>
</form>